<!DOCTYPE html>
<html lang="ms">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>FOKUS AI | Belajar AI dalam Bahasa Melayu</title>

<meta name="description" content="Belajar AI dalam Bahasa Melayu bersama FOKUS AI">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;700;800&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

html{

scroll-behavior:smooth;

}

body{

font-family:'Poppins',sans-serif;

background:url("BACK GROUND.png") center center no-repeat;

background-size:cover;

background-attachment:fixed;

color:#fff;

overflow-x:hidden;

min-height:100vh;

position:relative;

}

body::before{

content:"";

position:fixed;

inset:0;

background:
linear-gradient(rgba(5,10,30,.55),rgba(5,10,30,.55));

z-index:-2;

}

body::after{

content:"";

position:fixed;

inset:0;

backdrop-filter:blur(2px);

z-index:-1;

}

.hero{

width:100%;

min-height:100vh;

display:flex;

justify-content:center;

align-items:center;

padding:60px 20px;

}

.card{

width:100%;

max-width:760px;

padding:60px;

border-radius:28px;

background:rgba(255,255,255,.05);

border:1px solid rgba(255,255,255,.15);

backdrop-filter:blur(16px);

box-shadow:

0 20px 60px rgba(0,0,0,.45),

0 0 30px rgba(0,140,255,.18);

text-align:center;

animation:fadeUp 1s ease;

}

.subtitle{

font-family:'Space Grotesk',sans-serif;

font-size:58px;

font-weight:800;

line-height:1.1;

letter-spacing:-2px;

margin-bottom:18px;

text-shadow:

0 0 12px rgba(100,170,255,.8),

0 0 30px rgba(70,120,255,.35);

}

.youtube{

font-family:'Space Grotesk',sans-serif;

font-size:96px;

font-weight:800;

line-height:1;

margin-bottom:30px;

background:linear-gradient(90deg,#ffffff,#9ec9ff);

-webkit-background-clip:text;

-webkit-text-fill-color:transparent;

text-shadow:

0 0 25px rgba(120,180,255,.45);

}

.logo{

margin:20px auto 25px;

width:180px;

}

.logo img{

width:100%;

display:block;

filter:drop-shadow(0 0 25px rgba(0,160,255,.7));

}

.brand{

font-family:'Space Grotesk',sans-serif;

font-size:52px;

font-weight:700;

letter-spacing:3px;

margin-bottom:40px;

}

.button{

display:inline-flex;

align-items:center;

justify-content:center;

text-decoration:none;

padding:18px 50px;

border-radius:60px;

font-size:22px;

font-weight:700;

color:#fff;

background:

linear-gradient(135deg,#7d3cff,#249dff);

transition:.35s;

box-shadow:

0 10px 35px rgba(0,120,255,.35);

}

.button:hover{

transform:translateY(-5px);

box-shadow:

0 15px 45px rgba(0,120,255,.55),

0 0 35px rgba(140,60,255,.6);

}

@keyframes fadeUp{

from{

opacity:0;

transform:translateY(50px);

}

to{

opacity:1;

transform:translateY(0);

}

}

/* ===========================
      Tablet
=========================== */

@media (max-width:991px){

.card{

max-width:640px;

padding:45px;

}

.subtitle{

font-size:46px;

}

.youtube{

font-size:74px;

}

.logo{

width:150px;

}

.brand{

font-size:42px;

}

.button{

font-size:20px;

padding:16px 40px;

}

}

/* ===========================
      Mobile
=========================== */

@media (max-width:768px){

.hero{

padding:30px 15px;

}

.card{

padding:35px 25px;

border-radius:20px;

}

.subtitle{

font-size:34px;

letter-spacing:-1px;

}

.youtube{

font-size:54px;

}

.logo{

width:115px;

}

.brand{

font-size:32px;

letter-spacing:2px;

}

.button{

width:100%;

font-size:18px;

padding:15px;

}

}

/* ===========================
      Small Mobile
=========================== */

@media (max-width:430px){

.subtitle{

font-size:28px;

}

.youtube{

font-size:42px;

}

.logo{

width:90px;

}

.brand{

font-size:28px;

}

}

</style>

</head>

<body>

<section class="hero">

<div class="card">

<div class="subtitle">

Belajar AI<br>
dalam Bahasa Melayu di

</div>

<div class="youtube">

YouTube

</div>

<div class="logo">

<img src="LOGO.png" alt="FOKUS AI">

</div>

<div class="brand">

FOKUS AI

</div>

<a href="https://www.youtube.com/@FokusAiMalay" target="_blank" class="button">

Belajar Sekarang

</a>

</div>

</section>

<script>

// Hover Animation
const button = document.querySelector(".button");

button.addEventListener("mouseenter", () => {

    button.style.transform = "translateY(-5px) scale(1.03)";

});

button.addEventListener("mouseleave", () => {

    button.style.transform = "translateY(0) scale(1)";

});

// Mouse Glow Effect
document.addEventListener("mousemove",(e)=>{

const x = (e.clientX / window.innerWidth - 0.5) * 20;
const y = (e.clientY / window.innerHeight - 0.5) * 20;

document.querySelector(".card").style.transform =
`rotateY(${x}deg) rotateX(${-y}deg)`;

});

document.addEventListener("mouseleave",()=>{

document.querySelector(".card").style.transform =
"rotateY(0deg) rotateX(0deg)";

});

// Fade in
window.addEventListener("load",()=>{

document.querySelector(".card").style.opacity="1";

});
</script>

</body>

</html>
